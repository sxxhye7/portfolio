    <script>
        const navContainer = document.getElementById('nav-container');
        const navWrapper = document.getElementById('nav-wrapper');

        // Handling Navigation Sticky Logic
        window.addEventListener('scroll', () => {
            const wrapperTop = navWrapper.getBoundingClientRect().top;
            
            // Scroll offset check (utility bar height = 56px)
            if (wrapperTop <= 72) { 
                navContainer.classList.add('is-sticky');
            } else {
                navContainer.classList.remove('is-sticky');
            }

            // Scroll Spying for active section
            let current = '';
            const sections = document.querySelectorAll('section');
            sections.forEach(section => {
                const sectionTop = section.offsetTop;
                if (pageYOffset >= (sectionTop - 120)) {
                    current = section.getAttribute('id');
                }
            });

            const navItems = document.querySelectorAll('.nav-pill');
            navItems.forEach(item => {
                item.classList.remove('nav-active');
                if (item.getAttribute('href').includes(current)) {
                    item.classList.add('nav-active');
                }
            });
        });

        // Smooth scroll for internal nav links
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const targetId = this.getAttribute('href');
                const targetElement = document.querySelector(targetId);
                
                if (targetElement) {
                    const offset = 80; 
                    window.scrollTo({
                        top: targetElement.offsetTop - offset,
                        behavior: 'smooth'
                    });
                }
            });
        });
    </script>
